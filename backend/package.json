    "fastify": "^5.9.0",
    "fastify-plugin": "^6.0.0",
    "ioredis": "^5.11.1",
    "jsonwebtoken": "^9.0.3",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "web-push": "^3.6.7",
